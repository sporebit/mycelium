# =============================================================================
# MYCELIUM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# AUTH GATE
# -----------------------------------------------------------------------------

# 32-byte random hex used to sign HMAC auth cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Password to access the dashboard UI.
DASHBOARD_PASSWORD=

# Random hex secret for programmatic API access (cron, CLI).
# Passed as the x-api-secret header.
# Generate with: openssl rand -hex 32
API_SECRET=

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------

# Your Supabase project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / publishable key — safe for the browser, subject to RLS.
# New format uses the sb_publishable_ prefix.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role / secret key — server-side only, bypasses RLS.
# New format uses the sb_secret_ prefix. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# AI PROVIDERS
# -----------------------------------------------------------------------------

# Anthropic Claude — used for classification, routing, and summarisation.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — used for text-embedding-3-small (1536-dim) for memory_chunks,
# Whisper transcription, and as classifier fallback.
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# TELEGRAM BOT
# -----------------------------------------------------------------------------

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# The secret token Telegram sends in X-Telegram-Bot-Api-Secret-Token headers
# to verify webhook authenticity. Set when registering the webhook.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Your Telegram user ID — used to restrict who can send messages to the bot.
TELEGRAM_USER_ID=

# -----------------------------------------------------------------------------
# GOOGLE CALENDAR
# -----------------------------------------------------------------------------

# Comma-separated iCal URLs for calendar feeds (from Google Calendar settings).
# Each URL is a private .ics link — treat them as secrets.
GOOGLE_CALENDAR_ICAL_URLS=

# -----------------------------------------------------------------------------
# DEPLOYMENT
# -----------------------------------------------------------------------------

# The public-facing URL of the deployed app (no trailing slash).
# Used for webhook registration, OG tags, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# IDENTITY
# -----------------------------------------------------------------------------

# Static user_id string used across all tables for this single-user setup.
USER_ID=phil

# IANA timezone for date math (e.g. "Europe/London").
USER_TIMEZONE=Europe/London
